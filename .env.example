# Directus CMS — public read, server-only write
DIRECTUS_URL=https://cms.sachcuahuy.com

# Server-only token for /api/orders route. Has full svc on orders + customers (api-orders role).
# NEVER prefix with NEXT_PUBLIC_*; never commit real value.
DIRECTUS_API_ORDERS_TOKEN=

# Public Directus assets origin used by browser <img> tags. Usually same as DIRECTUS_URL.
NEXT_PUBLIC_DIRECTUS_ASSETS_URL=https://cms.sachcuahuy.com

# HMAC secret for short-lived PII-reveal cookie on /xac-nhan/[token]. Generate with:
#   openssl rand -hex 32
COOKIE_SECRET=

# Shared secret for Directus Flow → Next.js /api/revalidate.
# Set same value in Vercel and Directus, then send as X-Revalidate-Secret.
REVALIDATE_SECRET=

# Used only when running scripts/setup-directus-flows.py.
REVALIDATE_URL=https://sachcuahuy.vercel.app/api/revalidate

# Optional: site origin for absolute URLs (canonical, OG, etc.)
NEXT_PUBLIC_SITE_URL=http://localhost:3000
